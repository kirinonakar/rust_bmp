import { Button, CheckBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Alpha PNG to 32bit BMP Converter";
    icon: @image-url("../app.ico");
    width: 650px;
    height: 450px;
    background: @linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);

    callback file-dropped(string, bool); // path, is_right_side
    callback load-clicked();
    callback combine-clicked();
    
    in-out property <string> status-text: "PNG 파일을 여기로 드래그 하세요";
    in-out property <string> sub-status: "알파 채널이 포함된 32비트 BMP로 변환됩니다";
    in-out property <bool> is-hovering: false;
    in-out property <bool> with-background: false;
    
    // Properties for combined mode/previews
    in-out property <string> bg-path: "";
    in-out property <string> alpha-path: "";
    in-out property <image> bg-preview: @image-url("");
    in-out property <image> alpha-preview: @image-url("");
    in-out property <image> single-preview: @image-url("");

    VerticalLayout {
        padding: 30px;
        spacing: 15px;
        alignment: center;

        // Title
        Text {
            text: "PNG to BMP Converter";
            font-size: 28px;
            font-weight: 800;
            color: #e94560;
            horizontal-alignment: center;
        }

        // CheckBox with brighter Background for better visibility
        Rectangle {
            background: #ffffff25;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ffffff30;
            HorizontalLayout {
                padding: 10px;
                padding-left: 15px;
                padding-right: 15px;
                alignment: center;
                spacing: 12px;
                CheckBox {
                    checked <=> with-background;
                }
                Text {
                    text: "배경 있음 (파일 2개 합치기)";
                    color: with-background ? #e94560 : #ffffff;
                    vertical-alignment: center;
                    font-size: 16px;
                    font-weight: 800;
                    animate color { duration: 200ms; }
                }
            }
        }

        if !with-background : Rectangle {
            height: 180px;
            background: is-hovering ? #ffffff10 : #ffffff05;
            border-radius: 16px;
            border-width: 2px;
            border-color: is-hovering ? #e94560 : #ffffff20;
            animate background { duration: 200ms; }
            animate border-color { duration: 200ms; }

            Image {
                source: single-preview;
                width: 100%;
                height: 100%;
                image-fit: contain;
                opacity: 0.2;
            }

            VerticalLayout {
                alignment: center;
                spacing: 12px;
                
                Text {
                    text: status-text;
                    font-size: 16px;
                    color: #ffffff;
                    horizontal-alignment: center;
                }

                Text {
                    text: sub-status;
                    font-size: 13px;
                    color: #ffffff80;
                    horizontal-alignment: center;
                }
            }
        }

        if with-background : HorizontalLayout {
            spacing: 20px;
            height: 180px;

            // Left side: Background (RGB)
            Rectangle {
                background: #ffffff05;
                border-radius: 12px;
                border-width: 2px;
                border-color: bg-path != "" ? #e94560 : #ffffff20;
                
                Image {
                    source: bg-preview;
                    width: 100%;
                    height: 100%;
                    image-fit: contain;
                    opacity: 0.4;
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: "1. 배경 있는 PNG";
                        font-size: 14px;
                        color: #e94560;
                        horizontal-alignment: center;
                        font-weight: 700;
                    }
                    Text {
                        text: bg-path == "" ? "여기에 드롭" : bg-path;
                        font-size: 12px;
                        color: #ffffff;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                    if bg-path != "" : Text {
                        text: "(PNG, JPG, BMP 지원)";
                        font-size: 10px;
                        color: #ffffff60;
                        horizontal-alignment: center;
                    }
                    if bg-path == "" : Text {
                        text: "(PNG, JPG, BMP 가능)";
                        font-size: 10px;
                        color: #ffffff40;
                        horizontal-alignment: center;
                    }
                }
            }

            // Right side: Alpha
            Rectangle {
                background: #ffffff05;
                border-radius: 12px;
                border-width: 2px;
                border-color: alpha-path != "" ? #e94560 : #ffffff20;

                Image {
                    source: alpha-preview;
                    width: 100%;
                    height: 100%;
                    image-fit: contain;
                    opacity: 0.4;
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: "2. 투명한 PNG";
                        font-size: 14px;
                        color: #e94560;
                        horizontal-alignment: center;
                        font-weight: 700;
                    }
                    Text {
                        text: alpha-path == "" ? "여기에 드롭" : alpha-path;
                        font-size: 12px;
                        color: #ffffff;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                    if alpha-path != "" : Text {
                        text: "(알파 소스)";
                        font-size: 10px;
                        color: #ffffff60;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        if with-background : Button {
            text: "합쳐서 BMP로 저장";
            enabled: bg-path != "" && alpha-path != "";
            clicked => { root.combine-clicked(); }
        }

        if !with-background : Button {
            text: "PNG 파일 열기";
            clicked => { root.load-clicked(); }
        }
    }
}
