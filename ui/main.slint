import { Button } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Alpha PNG to 32bit BMP Converter";
    width: 600px;
    height: 400px;
    background: @linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);

    callback file-dropped(string);
    callback load-clicked();
    in-out property <string> status-text: "Drag and Drop a PNG file here";
    in-out property <string> sub-status: "Output will be a 32-bit BMP with Alpha Channel";
    in-out property <bool> is-hovering: false;

    VerticalLayout {
        padding: 40px;
        spacing: 20px;
        alignment: center;

        // Title
        Text {
            text: "PNG to BMP Converter";
            font-size: 28px;
            font-weight: 800;
            color: #e94560;
            horizontal-alignment: center;
        }

        // Drop Area
        drop-area := Rectangle {
            height: 200px;
            background: is-hovering ? #ffffff10 : #ffffff05;
            border-radius: 16px;
            border-width: 2px;
            border-color: is-hovering ? #e94560 : #ffffff20;
            animate background { duration: 200ms; }
            animate border-color { duration: 200ms; }

            // Drop area visual focus
            TouchArea {
                width: 100%;
                height: 100%;
                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down) {
                        // Just for visual effect if needed
                    }
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 12px;
                
                Rectangle {
                    width: 64px;
                    height: 64px;
                    background: is-hovering ? #e94560 : #ffffff20;
                    border-radius: 32px;
                    Text {
                        text: "↑";
                        font-size: 32px;
                        color: #ffffff;
                    }
                }

                Text {
                    text: status-text;
                    font-size: 18px;
                    color: #ffffff;
                    horizontal-alignment: center;
                }

                Text {
                    text: sub-status;
                    font-size: 14px;
                    color: #ffffff80;
                    horizontal-alignment: center;
                }
            }
        }

        // Info area
        Button {
            text: "Load PNG File";
            clicked => { root.load-clicked(); }
        }

        Text {
            text: "Compatible with Photoshop 32-bit (ARGB)";
            font-size: 12px;
            color: #ffffffa0;
            horizontal-alignment: center;
        }
    }

    // Capture dropping through the window
    // In Rust side, we will handle the WindowEvent::DroppedFile
}
